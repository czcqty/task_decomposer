# Optional: auto chooses the first provider with a configured API key.
# Supported providers: openai, chatgpt, claude, deepseek, custom.
LLM_PROVIDER=auto

# OpenAI / ChatGPT
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Claude / Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-5-haiku-latest

# DeepSeek, using an OpenAI-compatible API.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Other OpenAI-compatible services.
CUSTOM_API_KEY=your_custom_api_key_here
CUSTOM_MODEL=gpt-4.1-mini
CUSTOM_BASE_URL=https://your-compatible-endpoint.example.com/v1

# Skills
SKILLS_DIR=skills

# Project-level agents and skills
# PROJECT_NAME=demo
# PROJECT_DIR=skills/project/demo

# Runtime project config
RUNTIME_DIR=project
# CONVERSATION_ID=default

# Web search
# auto uses Tavily when TAVILY_API_KEY is set; otherwise DuckDuckGo Instant Answer.
SEARCH_PROVIDER=auto
SEARCH_MAX_RESULTS=5
TAVILY_API_KEY=your_tavily_api_key_here
